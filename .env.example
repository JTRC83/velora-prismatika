# Velora Prismátika — Variables de entorno
# Copia este archivo como .env.local y ajusta los valores si es necesario.

# --- Ollama (IA local) ---
# Modelo que usa Velora para generar respuestas
OLLAMA_MODEL=qwen3:14b
# Contexto máximo (tokens de ventana)
OLLAMA_NUM_CTX=8192
# Tokens máximos a generar por respuesta
OLLAMA_NUM_PREDICT=1600
# URL base de Ollama (por defecto localhost)
# OLLAMA_BASE_URL=http://127.0.0.1:11434

# --- Bóveda de conocimiento (Obsidian) ---
# Ruta a la bóveda de Obsidian indexada por el servicio de conocimiento
VELORA_VAULT_PATH=/Users/joantoniramoncrespi/Documents/Velora Prismätika

# --- Launcher macOS (opcional) ---
# Ruta a la imagen base para generar el icono de la app
# VELORA_ICON_SOURCE=/ruta/a/tu/icono.png